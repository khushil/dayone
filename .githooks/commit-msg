#!/bin/bash
# Commit Message Hook -- Validate conventional commit format + WI linkage.
#
# Layer 1 (US #2195, Bug #3508): conventional commit format
#   type(scope): description, types in
#   {feat, fix, docs, refactor, test, chore, build, spike}.
#   `spike` was added under Bug #3508 to match the codebase's first-class
#   Spike support (the branch-prefix regex below, `mle wi author --type spike`,
#   and the Spike-as-User-Story title-prefix convention).
#
# Layer 2 (US #2199): work-item link enforcement
#   If the current branch name does NOT carry a numeric work-item id matching
#   <prefix>/<wi-type>-<id>-<slug>, the commit message MUST contain an
#   explicit `#<id>` reference. release/<x.y.z> branches are exempt because
#   they bind via PR-time linkage. The unlinked-branch escape hatches
#   bypass this layer:
#     - MLE_ALLOW_UNLINKED_BRANCH=1            (env var, one-shot)
#     - git config mle.allow-unlinked true     (per-repo, persistent)
#
# !!MLE-MANAGED!! commit-msg@v3 (US #2195 + #2199 + Bug #3508)

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")
COMMIT_MSG_FULL=$(cat "$COMMIT_MSG_FILE")

# Allow merge commits and revert commits to bypass both layers.
if echo "$COMMIT_MSG" | grep -qE "^(Merge|Revert) "; then
    exit 0
fi

# --- Layer 1: conventional commit format ------------------------------------
PATTERN="^(feat|fix|docs|refactor|test|chore|build|spike)(\([a-zA-Z0-9_-]+\))?: .{1,}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo "================================================================"
    echo "  REJECTED: Commit message does not follow conventional format."
    echo "================================================================"
    echo ""
    echo "  Expected: type(scope): description"
    echo "  Allowed types: feat, fix, docs, refactor, test, chore, build, spike"
    echo ""
    echo "  Examples:"
    echo "    feat(core): add clone health check"
    echo "    fix(ado): correct work item linking"
    echo "    docs: update developer workflow guide"
    echo "    spike(hygiene): investigate option A versus option B"
    echo ""
    echo "  Your message: $COMMIT_MSG"
    echo ""
    exit 1
fi

# --- Layer 2: WI linkage (US #2199) -----------------------------------------
# Skip if the unlinked-branch escape hatch is active.
if [[ "${MLE_ALLOW_UNLINKED_BRANCH:-}" == "1" ]]; then
    exit 0
fi
if [[ "$(git config --get mle.allow-unlinked 2>/dev/null || true)" == "true" ]]; then
    exit 0
fi

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)
[[ -z "$CURRENT_BRANCH" ]] && exit 0

# main / master and other unprefixed branches are not policed here -- the
# pre-push hook catches the wrong-target case.
if [[ ! "$CURRENT_BRANCH" =~ ^(feature|bugfix|hotfix|release)/ ]]; then
    exit 0
fi

# release/<x.y.z> short-circuits Layer 2.
if [[ "$CURRENT_BRANCH" =~ ^release/[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.-]+)?$ ]]; then
    exit 0
fi

# Extract the numeric id from the branch name if present.
branch_wi_id=""
if [[ "$CURRENT_BRANCH" =~ ^(feature|bugfix|hotfix|release)/(refactor|security|feature|story|spike|task|test|bug|doc|pbi|us)-([0-9]+)(-.*)?$ ]]; then
    branch_wi_id="${BASH_REMATCH[3]}"
fi

# If the branch carries an id, the commit message does not need to repeat it.
if [[ -n "$branch_wi_id" ]]; then
    exit 0
fi

# Otherwise require the commit message to mention #<id>.
if echo "$COMMIT_MSG_FULL" | grep -qE '#[0-9]+'; then
    exit 0
fi

cat >&2 <<EOF

================================================================
  REJECTED: Commit message lacks a work-item reference.
================================================================

  Branch '$CURRENT_BRANCH' has no <wi-type>-<id> in its name, so the
  commit message MUST contain a '#<ADO-ID>' reference.

  Either:
    - Add '#<ID>' to your commit message, or
    - Recreate the branch using mle work <ADO-ID>, or
    - Bypass: MLE_ALLOW_UNLINKED_BRANCH=1 git commit -m '...'   (one-shot)
    - Bypass: git config mle.allow-unlinked true                 (per-repo)

EOF
exit 1
