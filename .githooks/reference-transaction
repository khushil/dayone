#!/usr/bin/env bash
# =============================================================================
# Git ref-transaction hook -- block in-place branching AND malformed branch
# names that fail the work-item link convention.
# =============================================================================
# Author: MLE (User Stories #2195 + #2199, Feature #2194 -- MLE Workspace Guard)
# !!MLE-MANAGED!! reference-transaction@v2 (US #2195 + #2199)
#
# Triggers on every ref transaction (Git >= 2.28). Reads stdin lines of the
# form "<old-oid> <new-oid> <ref-name>" during the `prepared` phase and
# applies two stackable guards:
#
#   1. Link guard (Layer 1, US #2199): every newly-created branch under
#      refs/heads/(feature|bugfix|hotfix|release)/ must match the canonical
#      regex <prefix>/<wi-type>-<id>-<slug> with a numeric <id> AND the
#      <wi-type> must be compatible with the prefix. release/<x.y.z> is
#      exempt. Cheap regex check; no ADO call. (Pre-push runs Layer 3.)
#   2. Location guard (US #2195): branch creation in the home repo is
#      blocked. The home repo is detected by checking whether toplevel is
#      NOT inside a *-clones/ or *-worktrees/ ancestor. `git worktree add`
#      is allowed because that is the prescribed alternative.
#
# Both guards are independent. Each has its own escape hatches; bypassing
# one does NOT bypass the other.
#
# Link guard hatches (US #2199):
#   - MLE_ALLOW_UNLINKED_BRANCH=1            (env var, one-shot)
#   - git config mle.allow-unlinked true     (per-repo, persistent)
#
# Location guard hatches (US #2195):
#   - MLE_ALLOW_INPLACE_BRANCH=1             (env var, one-shot)
#   - git config mle.allow-inplace true      (per-repo, persistent)
#
# KNOWN GAP -- silent on Git < 2.28: this hook is silently ignored by older
# git versions. Story #2198 (mle doctor integration) will surface that fact
# to the user. Until then, the Claude Code branch-guard.sh layer still fires
# for tool-driven branching; only direct human git use on Git < 2.28 escapes.
#
# Allowed (exit 0 in either guard):
#   - switching to an existing branch (HEAD update, not refs/heads creation)
#   - branch deletion (new-oid is all-zero)
#   - branch rename (paired delete+create on the same oid)
#   - branches outside refs/heads/(feature|bugfix|hotfix|release)/...
#
# Exit codes follow the git hook protocol:
#   0  -> allow the transaction
#   1  -> reject the transaction with a stderr message naming the layer

set -u

PHASE="${1:-}"
[[ "$PHASE" == "prepared" ]] || exit 0

# --- Walk PPID ancestry for `git worktree add` invocations -------------------
# `git worktree add ... -b foo` IS the prescribed alternative to in-place
# branching, so we must not fire the LOCATION guard for it. The LINK guard
# still applies -- a worktree with a malformed branch name is still a bug.
ancestor_has_worktree() {
    local pid="${1:-}"
    local depth=0
    while [[ -n "$pid" && "$pid" != "0" && $depth -lt 4 ]]; do
        local cmd=""
        if [[ -r "/proc/$pid/cmdline" ]]; then
            cmd=$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null || true)
        elif command -v ps >/dev/null 2>&1; then
            cmd=$(ps -o args= -p "$pid" 2>/dev/null || true)
        else
            return 1
        fi
        if [[ "$cmd" =~ ^([^[:space:]]+/)?git[[:space:]-]worktree([[:space:]]|$) ]]; then
            return 0
        fi
        if [[ -r "/proc/$pid/status" ]]; then
            pid=$(awk '/^PPid:/{print $2}' "/proc/$pid/status" 2>/dev/null || echo "")
        else
            pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ' || echo "")
        fi
        depth=$((depth + 1))
    done
    return 1
}

is_inside_workspace() {
    local p="$1"
    while [[ -n "$p" && "$p" != "/" ]]; do
        local base
        base=$(basename "$p")
        case "$base" in
            *-clones|*-worktrees) return 0 ;;
        esac
        p=$(dirname "$p")
    done
    return 1
}

toplevel=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
home_repo_name=$(basename "$toplevel")

# Pre-compute escape hatch states.
inplace_escape=0
if [[ "${MLE_ALLOW_INPLACE_BRANCH:-}" == "1" ]]; then
    inplace_escape=1
elif [[ "$(git config --get mle.allow-inplace 2>/dev/null || true)" == "true" ]]; then
    inplace_escape=1
fi

unlinked_escape=0
if [[ "${MLE_ALLOW_UNLINKED_BRANCH:-}" == "1" ]]; then
    unlinked_escape=1
elif [[ "$(git config --get mle.allow-unlinked 2>/dev/null || true)" == "true" ]]; then
    unlinked_escape=1
fi

worktree_add=0
if ancestor_has_worktree "$PPID"; then
    worktree_add=1
fi

inside_workspace=0
if is_inside_workspace "$toplevel"; then
    inside_workspace=1
fi

# --- Parse ref transactions --------------------------------------------------
declare -a creates_ref=() creates_oid=() deletes_oid=()
while read -r old_oid new_oid ref_name; do
    if [[ "$old_oid" =~ ^0+$ && ! "$new_oid" =~ ^0+$ ]]; then
        creates_ref+=("$ref_name")
        creates_oid+=("$new_oid")
    elif [[ "$new_oid" =~ ^0+$ && ! "$old_oid" =~ ^0+$ ]]; then
        deletes_oid+=("$old_oid")
    fi
done

# --- Branch-name link-guard regex (US #2199) --------------------------------
# Lower-case wi-type aliases:
#   us, story    -> User Story
#   pbi          -> Product Backlog Item
#   feature, bug, task, spike, refactor, doc, security, test, epic
# Note: longest alternatives first so the alternation matches greedily.
LINK_GUARD_RE='^refs/heads/(feature|bugfix|hotfix|release)/(refactor|security|feature|story|spike|task|test|epic|bug|doc|pbi|us)-([0-9]+)(-([a-z0-9][a-z0-9-]*[a-z0-9]|[a-z0-9]))?$'
RELEASE_VERSION_RE='^refs/heads/release/[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.-]+)?$'

# Type-compatibility check: prefix vs wi-type alias.
type_compatible() {
    local prefix="$1"
    local wi_type="$2"
    case "$prefix" in
        feature)
            case "$wi_type" in
                feature|story|us|pbi|task|spike|refactor|doc|security|test|epic) return 0 ;;
                *) return 1 ;;
            esac
            ;;
        bugfix|hotfix)
            [[ "$wi_type" == "bug" ]] && return 0
            return 1
            ;;
        release)
            return 0
            ;;
        *) return 1 ;;
    esac
}

# Iterate creates, skipping renames (delete+create on same oid).
for i in "${!creates_ref[@]}"; do
    ref="${creates_ref[$i]}"
    oid="${creates_oid[$i]}"
    is_rename=0
    if [[ ${#deletes_oid[@]} -gt 0 ]]; then
        for d in "${deletes_oid[@]}"; do
            if [[ "$d" == "$oid" ]]; then
                is_rename=1
                break
            fi
        done
    fi
    [[ $is_rename -eq 1 ]] && continue

    # Only branches under our four prefixes are policed at all.
    if [[ ! "$ref" =~ ^refs/heads/(feature|bugfix|hotfix|release)/ ]]; then
        continue
    fi

    branch="${ref#refs/heads/}"

    # --- Layer 1 link guard (regex + type compat). Independent of location. ----
    if [[ $unlinked_escape -eq 0 ]]; then
        # release/<x.y.z> short-circuits the link-guard regex.
        if [[ "$ref" =~ $RELEASE_VERSION_RE ]]; then
            link_ok=1
        elif [[ "$ref" =~ $LINK_GUARD_RE ]]; then
            prefix="${BASH_REMATCH[1]}"
            wi_type="${BASH_REMATCH[2]}"
            if type_compatible "$prefix" "$wi_type"; then
                link_ok=1
            else
                link_ok=0
                link_reason="prefix '${prefix}/' does not permit WI type '${wi_type}'"
            fi
        else
            link_ok=0
            link_reason="branch name does not match <prefix>/<wi-type>-<id>-<slug>"
        fi

        if [[ $link_ok -eq 0 ]]; then
            cat >&2 <<EOF

================================================================
  X  Branch link-guard rejected: $branch
================================================================

  Reason: $link_reason

  Convention: <prefix>/<wi-type>-<id>-<slug>
    prefix in  : feature, bugfix, hotfix, release
    wi-type in : feature, story, us, pbi, bug, task, spike,
                 refactor, doc, security, test
    id         : numeric ADO work item ID
    slug       : kebab-case description

  Compatibility:
    feature/   : feature, story, us, pbi, task, spike,
                 refactor, doc, security, test
    bugfix/    : bug
    hotfix/    : bug
    release/   : any (or release/<x.y.z> with no wi-id)

  Use:    mle work <ADO-ID>           (canonical workspace + WI link)
  Bypass: MLE_ALLOW_UNLINKED_BRANCH=1 git checkout -b ...   (one-shot)
  Bypass: git config mle.allow-unlinked true                (per-repo, persistent)

EOF
            exit 1
        fi
    fi

    # --- Location guard (home repo only, US #2195). ---------------------------
    if [[ $inplace_escape -eq 0 && $worktree_add -eq 0 && $inside_workspace -eq 0 ]]; then
        cat >&2 <<EOF

================================================================
  X  In-place branching blocked in home repo: $home_repo_name
================================================================

  Attempted to create: $ref

  Use:    mle work <ADO-ID>           (creates a workspace + links the work item)
  Or:     mle create <branch-name>    (workspace, --no-link --reason "..." --audit-wi <ID> to bypass linking)
  Bypass: MLE_ALLOW_INPLACE_BRANCH=1 git checkout -b ...   (one-shot)
  Bypass: git config mle.allow-inplace true                 (per-repo, persistent)

EOF
        exit 1
    fi
done

exit 0
