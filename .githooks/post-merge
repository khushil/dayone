#!/usr/bin/env bash
# =============================================================================
# Git post-merge hook — auto-reinstalls pipx mle when __version__ changes.
# =============================================================================
# !!MLE-MANAGED!! post-merge@v2 (US #2957, Feature #2278 — Tooling Hygiene; Bug #4365)
#
# Runs automatically after every successful `git pull` / `git merge`.
# Detects whether src/mle/__init__.py changed in the merge and, if so,
# compares the new version to the currently installed mle binary.
# When a mismatch is found, acts according to the detected install type:
#
#   pipx install  → pipx reinstall mle  (automatic, silent on success)
#   editable      → no-op (source is live; no reinstall needed)
#   system pip    → yellow warning; suggests manual upgrade
#   unknown       → yellow warning; no automated action
#
# Bug #4365: a failed `pipx reinstall mle` additionally writes a durable
# marker at ~/.mle/pipx-reinstall-failed.json so `mle doctor` can surface
# the failure later; the next successful reinstall removes the marker.
#
# This hook NEVER blocks the merge. Every error path exits 0.
# Disable per-repo: chmod -x .githooks/post-merge
# Disable globally: git config core.hooksPath ""
#
# Discipline: set -euo pipefail with || true on every tolerated failure.
# =============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Colour helpers (degrade gracefully when not a terminal)
# ---------------------------------------------------------------------------
_yellow() { printf '\033[0;33m%s\033[0m\n' "$*" >&2; }
_green()  { printf '\033[0;32m%s\033[0m\n' "$*" >&2; }

PREFIX="[mle post-merge]"

# ---------------------------------------------------------------------------
# Durable failure marker (Bug #4365)
# ---------------------------------------------------------------------------
# A failed `pipx reinstall mle` writes ~/.mle/pipx-reinstall-failed.json so
# `mle doctor` can surface the stale-install state after the terminal output
# has scrolled away.  A later successful reinstall deletes the marker.
# Every helper is guarded with || true — the marker must NEVER break the hook.

MARKER_FILE="${MLE_HOME:-${HOME}/.mle}/pipx-reinstall-failed.json"

# Minimal JSON string escaping in plain shell: fold newlines/tabs to spaces,
# strip remaining control characters, escape backslashes and double quotes.
_json_escape() {
    printf '%s' "$*" \
        | tr '\n\t' '  ' \
        | tr -d '\000-\037' \
        | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' \
        || true
}

# _write_failure_marker <target_version> <error_tail>
_write_failure_marker() {
    {
        marker_at=$(date -u +%Y-%m-%dT%H:%M:%SZ || true)
        mkdir -p "$(dirname "${MARKER_FILE}")"
        printf '{\n  "at": "%s",\n  "target_version": "%s",\n  "error": "%s"\n}\n' \
            "$(_json_escape "${marker_at}")" \
            "$(_json_escape "$1")" \
            "$(_json_escape "$2")" \
            > "${MARKER_FILE}"
    } 2>/dev/null || true
}

_clear_failure_marker() {
    rm -f "${MARKER_FILE}" 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# Step 1 — Determine whether src/mle/__init__.py changed in this merge.
# ---------------------------------------------------------------------------
# ORIG_HEAD is set by git pull/merge; use it when available so the diff is
# exactly the set of files brought in by the merge.  Fall back to HEAD^
# for cherry-picks and manual merges where ORIG_HEAD may be absent.
#
# We deliberately do NOT use `set -e` semantics here — git commands can fail
# in shallow clones or unusual repository states.  All git calls use || true.

version_file_changed=0

if git rev-parse --git-dir >/dev/null 2>&1; then
    git_dir=$(git rev-parse --git-dir 2>/dev/null || true)
    if [ -n "${git_dir}" ] && [ -f "${git_dir}/ORIG_HEAD" ]; then
        changed=$(git diff-tree -r --name-only ORIG_HEAD HEAD -- src/mle/__init__.py 2>/dev/null || true)
    else
        changed=$(git diff-tree -r --name-only HEAD^ HEAD -- src/mle/__init__.py 2>/dev/null || true)
    fi
    if echo "${changed}" | grep -q "src/mle/__init__.py"; then
        version_file_changed=1
    fi
fi

if [ "${version_file_changed}" -eq 0 ]; then
    # __init__.py untouched — nothing to do
    exit 0
fi

# ---------------------------------------------------------------------------
# Step 2 — Parse the new __version__ from HEAD.
# ---------------------------------------------------------------------------
new_version=""
new_version=$(git show HEAD:src/mle/__init__.py 2>/dev/null \
    | grep -E '^__version__\s*=' \
    | sed 's/__version__\s*=\s*"\(.*\)"/\1/' \
    | tr -d "'" \
    || true)

if [ -z "${new_version}" ]; then
    # Cannot parse version — warn and exit cleanly
    _yellow "${PREFIX} Could not parse __version__ from HEAD:src/mle/__init__.py — skipping auto-reinstall."
    exit 0
fi

# ---------------------------------------------------------------------------
# Step 3 — Get the currently installed version.
# ---------------------------------------------------------------------------
installed_version=""
if command -v mle >/dev/null 2>&1; then
    installed_version=$(mle --version 2>/dev/null \
        | sed 's/mle, version //' \
        | tr -d '[:space:]' \
        || true)
fi

if [ "${installed_version}" = "${new_version}" ]; then
    # Already up to date — idempotent no-op
    exit 0
fi

# ---------------------------------------------------------------------------
# Step 4 — Detect install type.
# ---------------------------------------------------------------------------
# Returns one of: pipx | editable | system | unknown
# All subshell calls use || true to tolerate missing binaries under set -euo pipefail.
detect_install_type() {
    local mle_path
    mle_path=$(command -v mle 2>/dev/null || true)
    if [ -z "${mle_path}" ]; then
        echo "unknown"
        return
    fi

    # Editable install — .venv/bin/pip show reports Editable project location.
    # Use || true so the whole pipeline never aborts under pipefail.
    local pip_show_output
    pip_show_output=$(.venv/bin/pip show mle 2>/dev/null || true)
    if echo "${pip_show_output}" | grep -qiE "^(Location|Editable project location):.*src/mle"; then
        echo "editable"
        return
    fi

    # pipx install — pipx list --short shows mle.
    # command -v pipx guards against pipx being absent entirely.
    if command -v pipx >/dev/null 2>&1; then
        local pipx_list
        pipx_list=$(pipx list --short 2>/dev/null || true)
        if echo "${pipx_list}" | awk '{print $1}' | grep -qx mle; then
            echo "pipx"
            return
        fi
    fi

    # System pip install — pip show works, not editable, not pipx.
    local sys_pip_output
    sys_pip_output=$(pip show mle 2>/dev/null || true)
    if echo "${sys_pip_output}" | grep -q "^Name:"; then
        echo "system"
        return
    fi

    echo "unknown"
}

install_type=$(detect_install_type)

# ---------------------------------------------------------------------------
# Step 5 — Act based on install type.
# ---------------------------------------------------------------------------
case "${install_type}" in
    pipx)
        # Automatic reinstall — pipx manages the isolated environment.
        # Capture combined output so the failure marker can carry the error
        # tail (Bug #4365).  || true keeps set -e from aborting the hook.
        reinstall_output=$(pipx reinstall mle 2>&1) && reinstall_ok=0 || reinstall_ok=$?
        if [ "${reinstall_ok}" -eq 0 ]; then
            _clear_failure_marker
            _green "${PREFIX} mle ${installed_version} → ${new_version} (pipx reinstall complete)"
        else
            # Durable signal for mle doctor — last 20 lines of the error
            error_tail=$(printf '%s\n' "${reinstall_output}" | tail -n 20 || true)
            _write_failure_marker "${new_version}" "${error_tail}"
            _yellow "${PREFIX} mle ${installed_version} → ${new_version} detected, but pipx reinstall failed."
            _yellow "  Run manually: pipx reinstall mle"
        fi
        ;;
    editable)
        # Source is live — no reinstall required
        exit 0
        ;;
    system)
        _yellow "${PREFIX} mle ${installed_version} → ${new_version} detected."
        _yellow "  System pip install detected; run manually: pip install --upgrade mle"
        ;;
    *)
        _yellow "${PREFIX} mle ${installed_version} → ${new_version} detected."
        _yellow "  Could not determine install type; run manually: pip install --upgrade mle"
        ;;
esac

# Always exit 0 — this hook never blocks a merge
exit 0
