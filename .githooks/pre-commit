#!/bin/bash
# Pre-Commit Hook — runs pre-commit framework checks on staged files
# Works with core.hooksPath; no `pre-commit install` needed.

# Guard: .pre-commit-config.yaml is generated at L3+.
# At L2, this hook is scaffolded but the config is not yet present.
# Exit 0 silently so the first commit on an L2 project is not blocked.
if [ ! -f ".pre-commit-config.yaml" ]; then
    echo "  [skip] .pre-commit-config.yaml not found — run 'mle init' at L3+ to generate it"
    exit 0
fi

if command -v pre-commit &>/dev/null; then
    exec pre-commit run
else
    echo "  [skip] pre-commit not installed — run scripts/setup-dev-environment.sh"
fi
