{
  "$comment": "Project hooks for DayONE. The PostToolUse hook enforces the Google TypeScript Style Guide by auto-formatting and lint-fixing every file Claude edits, surfacing any residual violations. An optional pre-commit gate lives in package.json scripts (npm run lint) — kept out of the hook so a red lint never blocks a live edit.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/lint-format.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/mle-watcher-hook.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/prompt-polish-auto.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/mle-doctor-auto.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/mle-conversation-capture.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/branch-guard.sh",
            "timeout": 5000,
            "_mle_managed": "branch-guard@v2"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "mle-hud"
  },
  "enabledPlugins": {
    "python3-development@claude-plugins-official": true
  }
}
