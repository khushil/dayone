{
  "name": "dayone",
  "version": "1.0.3",
  "description": "Track 12-month stock performance by market sector — a cross-platform desktop utility.",
  "main": "./out/main/index.js",
  "author": "Khushil Dep",
  "homepage": "https://github.com/khushil/dayone",
  "scripts": {
    "prepare": "lefthook install",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
    "fix": "eslint --fix . && stylelint --fix \"src/**/*.css\" && prettier --write .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "bdd": "node --import tsx node_modules/@cucumber/cucumber/bin/cucumber.js",
    "fetch-data": "tsx scripts/fetch-data.ts",
    "make-fixture": "node scripts/make-fixture.mjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.21.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@cucumber/cucumber": "^13.0.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "axe-core": "^4.12.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "puppeteer": "^25.2.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.2.6",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  }
}
